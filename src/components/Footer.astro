---
import EmailSVG from "./EmailSVG.astro";
import LinkedInSVG from "./LinkedInSVG.astro";
import Paragraph from "./Paragraph.astro";
---

<footer
   class="flex flex-col lg:flex-row items-center justify-center gap-4 lg:gap-0 lg:justify-between px-10 h-40 w-full dark:bg-dark-tiles-color rounded-3xl dark:text-white text-black bg-light-tiles-color animated inactive delayed"
>
   <div>
      <div data-lang="es">
         <Paragraph> Alejandro Juarez - Desarrollador Full Stack </Paragraph>
      </div>
      <div data-lang="en" hidden>
         <Paragraph> Alejandro Juarez - Full Stack Developer </Paragraph>
      </div>

      <div data-lang="es">
         <Paragraph>
            Pagina hecha con <span class="text-red-700 font-extrabold">Astro</span> y
            <span class="text-yellow-500 font-extrabold">Vanilla Javascript</span>
         </Paragraph>
      </div>
      <div data-lang="en" hidden>
         <Paragraph>
            Site built with <span class="text-red-700 font-extrabold">Astro</span> and
            <span class="text-yellow-500 font-extrabold">Vanilla Javascript</span>
         </Paragraph>
      </div>
   </div>
   <div
      class="flex flex-row items-center justify-center w-full lg:w-auto lg:flex-col gap-3"
   >
      <div
         class="flex w-auto lg:w-full justify-end gap-2 dark:text-white text-black text-2xl lg:text-base"
      >
         <a
            class="cursor-pointer"
            href="mailto:alejandro96laboral@gmail.com"
            target="_blank"
            aria-label="Send me an email"
         >
            <EmailSVG />
         </a>
         <a
            class="cursor-pointer"
            href="https://www.linkedin.com/in/alejandro-juarez96/"
            target="_blank"
            aria-label="Go to my linkedin"
         >
            <LinkedInSVG />
         </a>
      </div>
      <Paragraph propClasses="hidden sm:inline">
         <span data-lang="es">Ultima actualizacion: Marzo 2024</span>
         <span data-lang="en" hidden>Last update: March 2024</span>
      </Paragraph>
   </div>
</footer>
