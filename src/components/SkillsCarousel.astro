---
import skills from "../assets/json/Skills.json";
---

<div
   class="flex items-center justify-between px-10 h-40 w-full bg-slate-900 rounded-3xl dark:text-white text-black animated inactive delayed overflow-hidden relative"
>
   <div
      class="absolute left-0 h-full w-28 bg-gradient-to-r from-slate-900 to-transparent z-[1]"
   >
   </div>
   <div
      class="absolute right-0 h-full w-28 bg-gradient-to-l from-slate-900 to-transparent z-[1]"
   >
   </div>
   <div
      class="w-full inline-flex flex-nowrap overflow-hidden [mask-image:_linear-gradient(to_right,transparent_0,_black_128px,_black_calc(100%-200px),transparent_100%)]"
   >
      <ul
         class="flex items-center justify-center md:justify-start [&_li]:mx-8 [&_img]:max-w-none slide-track"
      >
         {
            skills.map((skill) => (
               <li class="mx-8">
                  <img
                     class="w-14 h-14 grayscale object-fill hover:grayscale-0 undefined"
                     src={skill.img}
                     alt={skill.name}
                     title={skill.name}
                  />
               </li>
            ))
         }
      </ul><ul
         class="flex items-center justify-center md:justify-start [&_li]:mx-8 [&_img]:max-w-none slide-track"
         aria-hidden="true"
      >
         {
            skills.map((skill) => (
               <li class="mx-8">
                  <img
                     class="w-14 h-14 grayscale object-fill hover:grayscale-0 undefined"
                     src={skill.img}
                     alt={skill.name}
                     title={skill.name}
                  />
               </li>
            ))
         }
      </ul>
   </div>
</div>
