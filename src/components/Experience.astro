---
import Card from "./Card.astro";
import SectionContainer from "./SectionContainer.astro";
import Experiences from "../assets/json/Experiences.json";
import proj1Img from "../assets/img/Municipalidad28.webp";
import proj2Img from "../assets/img/programming.webp";
import proj3Img from "../assets/img/computing.webp";

const images = [proj1Img, proj2Img, proj3Img];

const description = "You can see here all of my experience as a programmer";
const title = "Experience";
---

<SectionContainer title={title} description={description}>
   <div class="grid grid-cols-6 auto-rows-[260px] w-full gap-4">
      {
         Experiences.map((exp) => (
            <Card
               bgImg={images[exp.bgImg].src}
               logoImg={exp.logoImg}
               eName={exp.eName}
               rolName={exp.rolName}
               dates={exp.dates}
            />
         ))
      }
   </div>
</SectionContainer>
