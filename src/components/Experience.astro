---
import Card from "./Card.astro";
import SectionContainer from "./SectionContainer.astro";
import Experiences from "../assets/json/Experiences.json";

import proj1Img from "../assets/img/28Nov.webp";
import proj2Img from "../assets/img/teaching.jpg";
import proj3Img from "../assets/img/desk.webp";

import veitiochoNovLogo from "../assets/img/mun28nov.jpg";
import santaCruzLogo from "../assets/img/EscudoProvSantaCruz.png";
import zourceLogo from "../assets/img/logo.jpg";

const images = [proj1Img, proj2Img, proj3Img];
const logos = [veitiochoNovLogo, santaCruzLogo, zourceLogo];

const description = "My most relevant experiences";
const title = "Experience";
---

<SectionContainer title={title} description={description}>
   <div class="grid grid-cols-6 auto-rows-[260px] w-full gap-4">
      {
         Experiences.map((exp) => (
            <Card
               bgImg={images[exp.bgImg].src}
               logoImg={logos[exp.logoImg].src}
               rolName={exp.rolName}
               dates={exp.dates}
               pageLink={exp.pageLink}
            />
         ))
      }
   </div>
</SectionContainer>
