---
import Tile from "./GridTile.astro";
import AboutBtn from "./AboutBtn.astro";
import LinkedInSVG from "./LinkedInSVG.astro";
import EmailSVG from "./EmailSVG.astro";
import GithubSVG from "./GithubSVG.astro";
---

<section class="grid grid-cols-6 auto-rows-[172px] gap-4 w-full">
   <Tile propClasses="col-span-4 row-span-2 relative">
      <img
         src="src/assets/img/Foto-Portada.webp"
         class="w-full h-full object-cover absolute z-0"
      />
      <div class="absolute z-[1] flex flex-col w-full p-5 bottom-0 text-white">
         <span class="text-3xl font-bold leading-7"> Alejandro Juarez</span>
         <p class="leading-9 font-medium text-lg">
            Systems Analyst - FullStack Developer
         </p>
         <div class="flex gap-2 mt-1">
            <AboutBtn textBtn="Linkedin">
               <LinkedInSVG />
            </AboutBtn>
            <AboutBtn textBtn="Github">
               <GithubSVG />
            </AboutBtn>
            <AboutBtn textBtn="Email">
               <EmailSVG />
            </AboutBtn>
         </div>
      </div>
   </Tile>
   <Tile propClasses="col-span-2 p-7 justify-between">
      <span class="text-2xl font-bold">About</span>
      <p>
         Web developer with experience in designing, developing and maintaining
         front-end web applications.
      </p>
   </Tile>
   <Tile propClasses="items-center justify-center gap-2">
      <div class="flex text-7xl font-bold gap-1">
         <span>+</span>
         <span>1</span>
      </div>
      <p class="text-sm font-medium opacity-70 max-w-fit text-center">
         Years of experience
      </p>
   </Tile>
   <Tile>
      <div class="">
         <img
            class="w-full h-full opacity-70"
            src="src/assets/img/28DeNoviembre.png"
            alt="Map"
         />
      </div>
   </Tile>
</section>
