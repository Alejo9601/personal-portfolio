---
import ProjectLink from "./ProjectLink.astro";

const { projName, projDesc, projTechs, imgSource, projUrl } = Astro.props;
const { kindOfExperience = "WORK EXPERIENCE" } = Astro.props;
---

<div
   class="flex flex-col gap-3 w-full h-full top-0 left-0 p-8 relative on-hover-el"
>
   <div class="flex gap-3 items-center opacity-50">
      <svg
         fill="currentColor"
         xmlns="http://www.w3.org/2000/svg"
         id="Outline"
         viewBox="0 0 24 24"
         width="16"
         height="16"
         ><path
            d="M22.485,10.975,12,17.267,1.515,10.975A1,1,0,1,0,.486,12.69l11,6.6a1,1,0,0,0,1.03,0l11-6.6a1,1,0,1,0-1.029-1.715Z"
         ></path><path
            d="M22.485,15.543,12,21.834,1.515,15.543A1,1,0,1,0,.486,17.258l11,6.6a1,1,0,0,0,1.03,0l11-6.6a1,1,0,1,0-1.029-1.715Z"
         ></path><path
            d="M12,14.773a2.976,2.976,0,0,1-1.531-.425L.485,8.357a1,1,0,0,1,0-1.714L10.469.652a2.973,2.973,0,0,1,3.062,0l9.984,5.991a1,1,0,0,1,0,1.714l-9.984,5.991A2.976,2.976,0,0,1,12,14.773ZM2.944,7.5,11.5,12.633a.974.974,0,0,0,1,0L21.056,7.5,12.5,2.367a.974.974,0,0,0-1,0h0Z"
         ></path></svg
      >
      <span class="font-semibold">{kindOfExperience}</span>
   </div>
   <div class="flex flex-col gap-1">
      <h3 class="text-2xl font-bold">{projName}</h3>
      <p class="text-base opacity-70">{projDesc}</p>
      <div class="flex gap-2">
         {
            projTechs.map((tech: string) => (
               <span class="text-sm font-medium opacity-90">{tech}</span>
            ))
         }
      </div>
   </div>
   <ProjectLink pageUrl={projUrl} />
   <img
      src={imgSource}
      alt="project"
      class="rounded-2xl absolute w-full top-48 left-12 transition-all duration-300"
   />
</div>
