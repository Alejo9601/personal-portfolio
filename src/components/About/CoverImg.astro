---
import cover from "../../assets/img/coveronthesnow.webp";
import cover2 from "../../assets/img/coveronthesnow-md.webp";
import cover3 from "../../assets/img/coveronthesnow-sm.webp";
---

<picture class="w-full h-full object-cover absolute scale-x-[-1]">
   <source media="(width <= 500px)" srcset={cover3.src} />
   <source media="(width <= 768px)" srcset={cover2.src} />
   <img src={cover.src} />
</picture>

