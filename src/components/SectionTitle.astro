---
type BilingualText = {
   es: string;
   en: string;
};

interface Props {
   title: string | BilingualText;
   description: string | BilingualText;
}

const { title, description } = Astro.props as Props;

const titleText =
   typeof title === "string" ? { es: title, en: title } : title;
const descriptionText =
   typeof description === "string" ? { es: description, en: description } : description;
---

<header
   class="flex flex-col items-center justify-between w-full text-black dark:text-white inactive animated delayed"
>
   <h1 class="text-3xl font-bold">
      <span data-lang="es">{titleText.es}</span>
      <span data-lang="en" hidden>{titleText.en}</span>
   </h1>
   <p class="opacity-70 text-center">
      <span data-lang="es">{descriptionText.es}</span>
      <span data-lang="en" hidden>{descriptionText.en}</span>
   </p>
</header>
