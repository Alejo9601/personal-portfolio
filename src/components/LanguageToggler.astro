<button
   id="lang-toggle"
   type="button"
   class="flex items-center gap-1 rounded-xl px-2 py-1 text-sm font-semibold text-slate-700 hover:bg-slate-200/70 dark:text-slate-200 dark:hover:bg-slate-700/60"
   aria-label="Switch to English"
>
   <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
   >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M2 12h20"></path>
      <path d="M12 2a15.3 15.3 0 0 1 0 20"></path>
      <path d="M12 2a15.3 15.3 0 0 0 0 20"></path>
   </svg>
   <span data-lang-label>ES</span>
</button>
