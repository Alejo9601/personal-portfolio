---
interface Props {
   title: string;
}

const { title } = Astro.props;

import Header from "../components/Header.astro";
import "../assets/css/animations.css";
---

<!doctype html>
<html lang="en" class="dark dark:bg-slate-950">
   <head>
      <meta charset="UTF-8" />
      <meta name="description" content="Astro description" />
      <meta name="viewport" content="width=device-width" />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link
         href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&family=Quicksand:wght@300..700&display=swap"
         rel="stylesheet"
      />
      <script src="../js/OnProjectHover.ts"></script>
      <script src="../js/intersectionObserver.ts"></script>
      <meta name="generator" content={Astro.generator} /><title>
         {title}
      </title></head
   >
   <body class="flex flex-col items-center mb-10 font-outfit">
      <Header />
      <slot />
   </body>
</html>
