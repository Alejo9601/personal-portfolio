---
interface Props {
   title: string;
}

const { title } = Astro.props;

import Header from "../components/Header.astro";
import "../assets/css/animations.css";
import "../assets/css/font-faces.css";
---

<!doctype html>
<html lang="en" class="bg-light-back-color dark:bg-dark-back-color">
   <head>
      <meta charset="UTF-8" />
      <meta name="description" content="Astro description" />
      <meta name="viewport" content="width=device-width" />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <script src="../js/OnProjectHover.ts"></script>
      <script src="../js/intersectionObserver.ts"></script>
      <meta name="generator" content={Astro.generator} /><title>
         {title}
      </title></head
   >
   <body class="flex flex-col items-center mb-10 font-outfit">
      <Header />
      <slot />
      <script src="../js/darkModeListener.ts"></script>
   </body>
</html>
